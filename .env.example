# OANDA API Configuration
OANDA_API_KEY=your_api_key_here
OANDA_ACCOUNT_ID=your_account_id_here
OANDA_API_URL=https://api-fxpractice.oanda.com
OANDA_ENVIRONMENT=practice

# Trading Configuration
TRADING_ENABLED=false
MAX_POSITION_SIZE=1000
RISK_PER_TRADE=0.02
DEFAULT_STOP_LOSS_PIPS=50
DEFAULT_TAKE_PROFIT_PIPS=100

# Airtable Configuration
AIRTABLE_API_TOKEN=your_airtable_api_token_here
BASE_ID=your_base_id_here
TABLE_NAME=your_table_name_here

# Application Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs/trading.log
TIMEZONE=UTC

# Database Configuration (optional)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_bot
DB_USER=trading_user
DB_PASSWORD=your_password_here

# Notifications (optional)
NOTIFICATION_ENABLED=false
NOTIFICATION_WEBHOOK_URL=your_webhook_url_here