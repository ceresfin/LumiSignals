//@version=6
indicator("2n20 v2", overlay=true)

// ─── 2n20 v2 ───
// Differences vs. v1 (2n20.pine):
//   1. Anchor lookback (real red for buy / real green for sell) reduced 3 → 2 bars.
//   2. Adds a "neutral" anchor (small body + compressed range) at lookback k=1 only,
//      so a doji-on-VWAP that gets overtaken by a large opposite-color body still
//      triggers. Captures the indecision-then-resolution pattern v1 was filtering out.
//   3. Alert payloads tag strategy as "2n20_v2" so the bot tracks v2 separately
//      from v1 — run both Pine scripts on different charts to compare live.

// ─── SETTINGS ───
showExits = input.bool(true, "Show Exit Signals", group="Display")
showBias = input.bool(true, "Show Bias Background", group="Display")
minBodyPct = input.float(30.0, "Min Body Size (% of range)", step=5.0, group="Entry")

// Neutral-anchor knobs (v2-specific)
neutralBodyPct = input.float(25.0, "Neutral: max body % of range", step=5.0, group="Entry (v2)",
     tooltip="A bar with body% below this is considered neutral/doji and may anchor a signal at k=1.")
neutralRangeMult = input.float(0.7, "Neutral: max range as × avg10 range", step=0.1, group="Entry (v2)",
     tooltip="Range of the neutral bar must be below this multiple of the 10-bar average range.")

// ─── PAIR-SPECIFIC SETTINGS ───
vwapAnchorHour = input.int(18, "VWAP Anchor Hour (ET)", minval=0, maxval=23, group="Session",
     tooltip="Hour in ET when VWAP resets. 19=Tokyo open (JPY), 3=London open (EUR), 18=standard forex")

windowStart = input.int(0, "Window Start Hour (ET)", minval=0, maxval=23, group="Session",
     tooltip="First hour to allow new entries. Set 0 + end 24 for all hours.")
windowEnd = input.int(24, "Window End Hour (ET)", minval=0, maxval=24, group="Session",
     tooltip="Last hour for entries. Wraps: start=19 end=12 means 7PM-noon next day.")

// ─── MARKET HOURS ───
etHour = hour(time, "America/New_York")
etMinute = minute(time, "America/New_York")
etTime = etHour * 100 + etMinute

inWindow = windowStart < windowEnd ? (etHour >= windowStart and etHour < windowEnd) : (etHour >= windowStart or etHour < windowEnd)
inSession = not (etTime >= 1700 and etTime < 1800)

// ─── SESSION-ANCHORED VWAP ───
isNewSession = ta.change(etHour) != 0 and etHour == vwapAnchorHour
var dayVwapNum = 0.0
var dayVwapDen = 0.0
if isNewSession
    dayVwapNum := 0.0
    dayVwapDen := 0.0
dayVwapNum += hlc3 * volume
dayVwapDen += volume
vwapVal = dayVwapDen > 0 ? dayVwapNum / dayVwapDen : hlc3

aboveVwap = close > vwapVal
belowVwap = close < vwapVal

// ─── CANDLE DEFINITIONS ───
isGreen = close > open
isRed = close < open
greenBody = isGreen ? close - open : 0
redBody = isRed ? open - close : 0
prevGreenBody = isGreen[1] ? close[1] - open[1] : 0
prevRedBody = isRed[1] ? open[1] - close[1] : 0

// Neutral / doji detection (per-bar). Uses 10-bar avg range computed on
// previous bars only so the bar being evaluated doesn't influence its own
// threshold.
candleRangeNow = high - low
bodySizeNow = math.abs(close - open)
avgRange10 = ta.sma(candleRangeNow, 10)[1]
isNeutralBar(int k) =>
    rng = high[k] - low[k]
    bs = math.abs(close[k] - open[k])
    bp = rng > 0 ? (bs / rng) * 100 : 0
    bp < neutralBodyPct and rng < avgRange10 * neutralRangeMult

// ─── ANCHOR LOOKUP ───
// BUY side: real red within 2 bars, OR neutral at k=1 only.
// Prefer the closer anchor regardless of type — newest valid bar wins.
lastRedBody2 = isRed[1] ? prevRedBody : isRed[2] ? math.abs(open[2] - close[2]) : 0.0
lastRedHigh2 = isRed[1] ? open[1] : isRed[2] ? open[2] : 0.0

neutral1Bear = isNeutralBar(1)
neutralBearBody = neutral1Bear ? math.abs(close[1] - open[1]) : 0.0
// For a neutral bar the body top is meaningless (body ≈ 0), so use the bar's
// actual high — the close must clear the wick, not just the body.
neutralBearHigh = neutral1Bear ? high[1] : 0.0

// Combined anchor for BUY: prefer the closer one (k=1 wins over k=2).
useRedK1 = isRed[1]
useNeutK1 = not useRedK1 and neutral1Bear
useRedK2 = not useRedK1 and not useNeutK1 and isRed[2]

anchorBearBody = useRedK1 ? prevRedBody :
                 useNeutK1 ? neutralBearBody :
                 useRedK2 ? math.abs(open[2] - close[2]) : 0.0
anchorBearHigh = useRedK1 ? open[1] :
                 useNeutK1 ? high[1] :
                 useRedK2 ? open[2] : 0.0

// SELL side: real green within 2 bars, OR neutral at k=1 only.
lastGreenBody2 = isGreen[1] ? prevGreenBody : isGreen[2] ? math.abs(close[2] - open[2]) : 0.0
lastGreenLow2 = isGreen[1] ? open[1] : isGreen[2] ? open[2] : 0.0

neutral1Bull = isNeutralBar(1)
neutralBullBody = neutral1Bull ? math.abs(close[1] - open[1]) : 0.0
neutralBullLow = neutral1Bull ? low[1] : 0.0

useGreenK1 = isGreen[1]
useNeutK1Bull = not useGreenK1 and neutral1Bull
useGreenK2 = not useGreenK1 and not useNeutK1Bull and isGreen[2]

anchorBullBody = useGreenK1 ? prevGreenBody :
                 useNeutK1Bull ? neutralBullBody :
                 useGreenK2 ? math.abs(close[2] - open[2]) : 0.0
anchorBullLow = useGreenK1 ? open[1] :
                useNeutK1Bull ? low[1] :
                useGreenK2 ? open[2] : 0.0

// ─── BODY SIZE FILTER (trigger candle) ───
candleRange = high - low
bodySize = math.abs(close - open)
bodyPct = candleRange > 0 ? (bodySize / candleRange) * 100 : 0
hasRealBody = bodyPct >= minBodyPct

avgBody = ta.sma(math.abs(close - open), 10)
isSignificantBody = bodySize >= avgBody * 0.8

// ─── OVERWHELM DETECTION ───
greenOverwhelmsRed = isGreen and hasRealBody and isSignificantBody and anchorBearBody > 0 and greenBody > anchorBearBody and close > anchorBearHigh
redOverwhelmsGreen = isRed and hasRealBody and isSignificantBody and anchorBullBody > 0 and redBody > anchorBullBody and close < anchorBullLow

// ─── TRADE SIGNALS ───
buySignal = inSession and inWindow and aboveVwap and greenOverwhelmsRed
sellSignal = inSession and inWindow and belowVwap and redOverwhelmsGreen

// ─── EXIT SIGNALS ───
exitLong = redOverwhelmsGreen
exitShort = greenOverwhelmsRed

crossedBelowVwap = close < vwapVal and close[1] >= vwapVal
crossedAboveVwap = close > vwapVal and close[1] <= vwapVal

// ─── TRADE STATE TRACKING ───
var inLong = false
var inShort = false

if buySignal and not inLong
    inLong := true
    inShort := false
if sellSignal and not inShort
    inShort := true
    inLong := false
if inLong and exitLong
    inLong := false
if inShort and exitShort
    inShort := false
if inLong and crossedBelowVwap
    inLong := false
if inShort and crossedAboveVwap
    inShort := false

sessionEnd = etTime >= 1650 and etTime <= 1659
if inLong and sessionEnd
    inLong := false
if inShort and sessionEnd
    inShort := false

// ─── PLOT VWAP ───
plot(vwapVal, "Daily VWAP", color=color.orange, linewidth=2)

biasColor = aboveVwap ? color.new(color.green, 93) : belowVwap ? color.new(color.red, 93) : na
bgcolor(showBias ? biasColor : na, title="VWAP Bias")

// ─── SIGNAL MARKERS ───
plotshape(buySignal and not inLong[1], "BUY", shape.triangleup, location.belowbar, color.lime, size=size.normal, text="BUY v2")
plotshape(sellSignal and not inShort[1], "SELL", shape.triangledown, location.abovebar, color.red, size=size.normal, text="SELL v2")

plotshape(showExits and inLong[1] and exitLong and not crossedBelowVwap, "Exit Long", shape.xcross, location.abovebar, color.orange, size=size.small, text="X")
plotshape(showExits and inShort[1] and exitShort and not crossedAboveVwap, "Exit Short", shape.xcross, location.belowbar, color.orange, size=size.small, text="X")

plotshape(showExits and inLong[1] and crossedBelowVwap and not sessionEnd, "VWAP Exit Long", shape.xcross, location.abovebar, color.yellow, size=size.small, text="VWAP X")
plotshape(showExits and inShort[1] and crossedAboveVwap and not sessionEnd, "VWAP Exit Short", shape.xcross, location.belowbar, color.yellow, size=size.small, text="VWAP X")

plotshape(showExits and inLong[1] and sessionEnd, "Session Close Long", shape.xcross, location.abovebar, color.white, size=size.small, text="4:59")
plotshape(showExits and inShort[1] and sessionEnd, "Session Close Short", shape.xcross, location.belowbar, color.white, size=size.small, text="4:59")

tradeColor = inLong ? color.new(color.green, 88) : inShort ? color.new(color.red, 88) : na
bgcolor(tradeColor, title="In Trade")

// Mark neutral-anchored entries distinctly so it's easy to see which v2 trades
// came from the new pattern vs. the classic red/green overwhelm.
neutralAnchoredBuy = buySignal and not inLong[1] and useNeutK1
neutralAnchoredSell = sellSignal and not inShort[1] and useNeutK1Bull
plotshape(neutralAnchoredBuy, "Neutral BUY", shape.circle, location.belowbar, color.aqua, size=size.tiny)
plotshape(neutralAnchoredSell, "Neutral SELL", shape.circle, location.abovebar, color.aqua, size=size.tiny)

// ─── DEBUG TABLE ───
showDebugTable = input.bool(true, "Show Debug Table", group="Debug")
maxDebugRows = input.int(10, "Max Debug Rows", minval=3, maxval=30, group="Debug")

var array<string> dbgTime = array.new<string>()
var array<string> dbgSig = array.new<string>()
var array<float> dbgO = array.new<float>()
var array<float> dbgH = array.new<float>()
var array<float> dbgL = array.new<float>()
var array<float> dbgC = array.new<float>()
var array<float> dbgV = array.new<float>()

addDebugRow(string sig) =>
    array.push(dbgTime, str.format_time(time, "HH:mm", "America/New_York"))
    array.push(dbgSig, sig)
    array.push(dbgO, open)
    array.push(dbgH, high)
    array.push(dbgL, low)
    array.push(dbgC, close)
    array.push(dbgV, vwapVal)
    while array.size(dbgTime) > maxDebugRows
        array.shift(dbgTime)
        array.shift(dbgSig)
        array.shift(dbgO)
        array.shift(dbgH)
        array.shift(dbgL)
        array.shift(dbgC)
        array.shift(dbgV)

if buySignal and not inLong[1]
    addDebugRow(useNeutK1 ? "BUYn" : "BUY")
if sellSignal and not inShort[1]
    addDebugRow(useNeutK1Bull ? "SELLn" : "SELL")
if inLong[1] and exitLong and not crossedBelowVwap and not sessionEnd
    addDebugRow("X-LONG")
if inShort[1] and exitShort and not crossedAboveVwap and not sessionEnd
    addDebugRow("X-SHORT")
if inLong[1] and crossedBelowVwap and not sessionEnd
    addDebugRow("VWAP-X-L")
if inShort[1] and crossedAboveVwap and not sessionEnd
    addDebugRow("VWAP-X-S")

var table dbgTable = table.new(position.top_right, 7, 32, border_width=1, frame_color=color.gray, frame_width=1)

if barstate.islast and showDebugTable
    headerBg = color.new(color.gray, 30)
    headerFg = color.white
    table.cell(dbgTable, 0, 0, "Time", bgcolor=headerBg, text_color=headerFg, text_size=size.small)
    table.cell(dbgTable, 1, 0, "Signal", bgcolor=headerBg, text_color=headerFg, text_size=size.small)
    table.cell(dbgTable, 2, 0, "Open", bgcolor=headerBg, text_color=headerFg, text_size=size.small)
    table.cell(dbgTable, 3, 0, "High", bgcolor=headerBg, text_color=headerFg, text_size=size.small)
    table.cell(dbgTable, 4, 0, "Low", bgcolor=headerBg, text_color=headerFg, text_size=size.small)
    table.cell(dbgTable, 5, 0, "Close", bgcolor=headerBg, text_color=headerFg, text_size=size.small)
    table.cell(dbgTable, 6, 0, "VWAP", bgcolor=headerBg, text_color=headerFg, text_size=size.small)

    n = array.size(dbgTime)
    fmt = syminfo.mintick < 0.001 ? "#.#####" : "#.##"
    if n > 0
        for i = 0 to n - 1
            idx = n - 1 - i
            sig = array.get(dbgSig, idx)
            bg = sig == "BUY" or sig == "BUYn" ? color.new(color.green, 75) :
                 sig == "SELL" or sig == "SELLn" ? color.new(color.red, 75) :
                 str.contains(sig, "VWAP") ? color.new(color.yellow, 75) :
                 color.new(color.orange, 75)
            table.cell(dbgTable, 0, i + 1, array.get(dbgTime, idx), bgcolor=bg, text_size=size.small)
            table.cell(dbgTable, 1, i + 1, sig, bgcolor=bg, text_size=size.small)
            table.cell(dbgTable, 2, i + 1, str.tostring(array.get(dbgO, idx), fmt), bgcolor=bg, text_size=size.small)
            table.cell(dbgTable, 3, i + 1, str.tostring(array.get(dbgH, idx), fmt), bgcolor=bg, text_size=size.small)
            table.cell(dbgTable, 4, i + 1, str.tostring(array.get(dbgL, idx), fmt), bgcolor=bg, text_size=size.small)
            table.cell(dbgTable, 5, i + 1, str.tostring(array.get(dbgC, idx), fmt), bgcolor=bg, text_size=size.small)
            table.cell(dbgTable, 6, i + 1, str.tostring(array.get(dbgV, idx), fmt), bgcolor=bg, text_size=size.small)

// ─── ALERTS ───
// Strategy tag is "2n20_v2" so the bot routes/tracks separately from v1.
tickerStr = syminfo.ticker
typeStr = syminfo.type == "forex" ? "forex" : "futures"

buyMsg = '{"ticker":"' + tickerStr + '","direction":"BUY","strategy":"2n20_v2","key":"lumisignals2026","type":"' + typeStr + '","contracts":1,"msg":"2n20_v2 BUY ' + tickerStr + ' — Long Entry"}'
sellMsg = '{"ticker":"' + tickerStr + '","direction":"SELL","strategy":"2n20_v2","key":"lumisignals2026","type":"' + typeStr + '","contracts":1,"msg":"2n20_v2 SELL ' + tickerStr + ' — Short Entry"}'
closeLongRedMsg = '{"ticker":"' + tickerStr + '","direction":"CLOSE_LONG","strategy":"2n20_v2","key":"lumisignals2026","type":"' + typeStr + '","reason":"Red Takeout Green","msg":"2n20_v2 EXIT LONG ' + tickerStr + ' — Red Takeout Green"}'
closeLongVwapMsg = '{"ticker":"' + tickerStr + '","direction":"CLOSE_LONG","strategy":"2n20_v2","key":"lumisignals2026","type":"' + typeStr + '","reason":"VWAP Cross","msg":"2n20_v2 EXIT LONG ' + tickerStr + ' — VWAP Cross"}'
closeShortGreenMsg = '{"ticker":"' + tickerStr + '","direction":"CLOSE_SHORT","strategy":"2n20_v2","key":"lumisignals2026","type":"' + typeStr + '","reason":"Green Takeout Red","msg":"2n20_v2 EXIT SHORT ' + tickerStr + ' — Green Takeout Red"}'
closeShortVwapMsg = '{"ticker":"' + tickerStr + '","direction":"CLOSE_SHORT","strategy":"2n20_v2","key":"lumisignals2026","type":"' + typeStr + '","reason":"VWAP Cross","msg":"2n20_v2 EXIT SHORT ' + tickerStr + ' — VWAP Cross"}'
sessionCloseLongMsg = '{"ticker":"' + tickerStr + '","direction":"CLOSE_LONG","strategy":"2n20_v2","key":"lumisignals2026","type":"' + typeStr + '","reason":"Session Close 4:59pm","msg":"2n20_v2 CLOSE ALL ' + tickerStr + ' — Session End 4:59pm"}'
sessionCloseShortMsg = '{"ticker":"' + tickerStr + '","direction":"CLOSE_SHORT","strategy":"2n20_v2","key":"lumisignals2026","type":"' + typeStr + '","reason":"Session Close 4:59pm","msg":"2n20_v2 CLOSE ALL ' + tickerStr + ' — Session End 4:59pm"}'

if buySignal and not inLong[1]
    alert(buyMsg, alert.freq_once_per_bar_close)
if sellSignal and not inShort[1]
    alert(sellMsg, alert.freq_once_per_bar_close)
if inLong[1] and exitLong and not crossedBelowVwap and not sessionEnd
    alert(closeLongRedMsg, alert.freq_once_per_bar_close)
if inLong[1] and crossedBelowVwap and not sessionEnd
    alert(closeLongVwapMsg, alert.freq_once_per_bar_close)
if inShort[1] and exitShort and not crossedAboveVwap and not sessionEnd
    alert(closeShortGreenMsg, alert.freq_once_per_bar_close)
if inShort[1] and crossedAboveVwap and not sessionEnd
    alert(closeShortVwapMsg, alert.freq_once_per_bar_close)
if inLong[1] and sessionEnd
    alert(sessionCloseLongMsg, alert.freq_once_per_bar_close)
if inShort[1] and sessionEnd
    alert(sessionCloseShortMsg, alert.freq_once_per_bar_close)
