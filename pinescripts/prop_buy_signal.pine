// Prop Buy Signal — Pine Script port from ThinkOrSwim
// Source: TOS Scripts/Prop Buy Signal.rtf
// Fires when ALL of the following are true on the current bar:
//   1. close > anchored VWAP (default daily anchor)
//   2. close > EMA(20)
//   3. close > EMA(45)
//   4. "Bullish engulfing": current bar's body extends above the prior bar's
//      body high AND the prior bar closed red
//@version=6
indicator("Prop Buy Signal", overlay=true)

// ─── INPUTS ───
avgLength1 = input.int(20,  "EMA Length 1",       minval=1, group="Moving Averages")
avgLength2 = input.int(45,  "EMA Length 2",       minval=1, group="Moving Averages")
avgOffset  = input.int(0,   "MA Offset (bars)",   minval=0, group="Moving Averages")
vwapAnchor = input.string("Day", "VWAP Anchor", options=["Day", "Week", "Month"], group="VWAP")
showMAs    = input.bool(true, "Plot VWAP & EMAs",      group="Display")
showArrow  = input.bool(true, "Show Buy Arrow on Bar", group="Display")

// ─── ANCHORED VWAP ───
anchor = switch vwapAnchor
    "Day"   => timeframe.change("D")
    "Week"  => timeframe.change("W")
    "Month" => timeframe.change("M")
    =>         timeframe.change("D")

vwap1 = ta.vwap(hlc3, anchor)

// ─── EMAs (with optional bar offset) ───
avg1Raw = ta.ema(close, avgLength1)
avg2Raw = ta.ema(close, avgLength2)
avg1 = avgOffset > 0 ? avg1Raw[avgOffset] : avg1Raw
avg2 = avgOffset > 0 ? avg2Raw[avgOffset] : avg2Raw

// ─── ENGULFING PATTERN (matches TOS definition exactly) ───
bodyMax = math.max(open, close)
prevRed = close[1] < open[1]
greenIsEngulfing = bodyMax > bodyMax[1] and prevRed

// ─── BULLISH SIGNAL ───
bullishSignal = close > vwap1 and close > avg1 and close > avg2 and greenIsEngulfing

// ─── PLOTS ───
plot(showMAs ? vwap1 : na, "VWAP",                            color=color.new(color.yellow, 0), linewidth=2)
plot(showMAs ? avg1  : na, "EMA " + str.tostring(avgLength1), color=color.new(color.aqua,   0), linewidth=1)
plot(showMAs ? avg2  : na, "EMA " + str.tostring(avgLength2), color=color.new(color.orange, 0), linewidth=1)
plotshape(showArrow and bullishSignal, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.normal, text="BUY")
bgcolor(bullishSignal ? color.new(color.lime, 85) : na, title="Buy Signal Bar")

// ─── ALERT ───
alertcondition(bullishSignal, "Prop Buy Signal", "Prop Buy Signal on {{ticker}} @ {{close}}")
