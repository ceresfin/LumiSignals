// Opening Range Breakout Strategy (ES/MES)
// Entry: Break of first 15-min bar (9:30-9:45 ET) high/low by 0.50 pts
// Stop: VIX-dependent (4 pts if VIX<25, full range if VIX>=25, half if range>20)
// Target: 20 points from entry
// Entry window: must trigger by 11:00 AM ET
//@version=6
indicator("ORB 9:30-9:45", overlay=true, max_lines_count=20, max_labels_count=20)

// ─── INPUTS ───
orbOffset    = input.float(0.50, "Breakout Offset (pts)", step=0.25, group="Entry")
target       = input.float(20.0, "Target (pts)", step=1.0, group="Exit")
lowVolStop   = input.float(4.0, "Stop (VIX < 25)", step=0.5, group="Exit")
vixThreshold = input.int(25, "VIX Threshold", group="Exit")
maxRangeStop = input.float(20.0, "Max Range for Full Stop", step=1.0, group="Exit", tooltip="If OR range > this, stop = range / 2")
showORB      = input.bool(true, "Show Opening Range Box", group="Display")
showLevels   = input.bool(true, "Show Entry/Target/Stop Lines", group="Display")

// ─── TIME ───
etHour   = hour(time, "America/New_York")
etMinute = minute(time, "America/New_York")
etTime   = etHour * 100 + etMinute

// Opening range: 9:30 - 9:45 ET (first 15-min bar)
isORPeriod  = etTime >= 930 and etTime < 945
isEntryWindow = etTime >= 945 and etTime <= 1100
isNewSession  = ta.change(time("D")) != 0

// ─── VIX ───
vixClose = request.security("TVC:VIX", "D", close)

// ─── OPENING RANGE TRACKING ───
var float orHigh = na
var float orLow  = na
var bool  orSet  = false

// Reset at new session
if isNewSession
    orHigh := na
    orLow  := na
    orSet  := false

// Build OR during 9:30-10:15
if isORPeriod
    if na(orHigh)
        orHigh := high
        orLow  := low
    else
        orHigh := math.max(orHigh, high)
        orLow  := math.min(orLow, low)

// Mark OR as complete at 10:15
if etTime == 945 and not na(orHigh) and not orSet
    orSet := true

// ─── ENTRY LEVELS ───
float buyEntry  = orSet ? orHigh + orbOffset : na
float sellEntry = orSet ? orLow - orbOffset : na
float orRange   = orSet ? orHigh - orLow : na

// ─── STOP LOSS CALCULATION ───
float stopSize = na
if orSet
    if vixClose < vixThreshold
        stopSize := lowVolStop
    else
        if orRange > maxRangeStop
            stopSize := orRange / 2
        else
            stopSize := orRange

// ─── TARGET ───
float buyTarget  = not na(buyEntry) ? buyEntry + target : na
float sellTarget = not na(sellEntry) ? sellEntry - target : na
float buyStop    = not na(buyEntry) and not na(stopSize) ? buyEntry - stopSize : na
float sellStop   = not na(sellEntry) and not na(stopSize) ? sellEntry + stopSize : na

// ─── TRADE STATE ───
var bool inLong    = false
var bool inShort   = false
var bool triggered = false  // First breakout taken
var bool reversed  = false  // Fakeout reversal taken (max 2 trades/day)
var bool stoppedOut = false // First trade hit stop loss
var string firstDir = ""   // "BUY" or "SELL" — what the first trade was
var float entryPrice = na
var float slPrice    = na
var float tpPrice    = na

// Reversal window: fakeout can trigger until 11:15 AM ET
isReversalWindow = etTime >= 945 and etTime <= 1115

// Reset at new session
if isNewSession
    inLong     := false
    inShort    := false
    triggered  := false
    reversed   := false
    stoppedOut := false
    firstDir   := ""
    entryPrice := na
    slPrice    := na
    tpPrice    := na

// ─── ENTRY SIGNALS ───
// First breakout (9:45-11:00)
buySignal  = orSet and isEntryWindow and not triggered and not inLong and not inShort and close > buyEntry
sellSignal = orSet and isEntryWindow and not triggered and not inLong and not inShort and close < sellEntry

// Fakeout reversal: first trade stopped out, price reaches opposite side (by 11:15)
reverseBuySignal  = orSet and isReversalWindow and stoppedOut and not reversed and not inLong and not inShort and firstDir == "SELL" and close > buyEntry
reverseSellSignal = orSet and isReversalWindow and stoppedOut and not reversed and not inLong and not inShort and firstDir == "BUY" and close < sellEntry

if buySignal
    inLong     := true
    triggered  := true
    firstDir   := "BUY"
    entryPrice := buyEntry
    slPrice    := buyStop
    tpPrice    := buyTarget

if sellSignal
    inShort    := true
    triggered  := true
    firstDir   := "SELL"
    entryPrice := sellEntry
    slPrice    := sellStop
    tpPrice    := sellTarget

if reverseBuySignal
    inLong     := true
    reversed   := true
    entryPrice := buyEntry
    slPrice    := buyStop
    tpPrice    := buyTarget

if reverseSellSignal
    inShort    := true
    reversed   := true
    entryPrice := sellEntry
    slPrice    := sellStop
    tpPrice    := sellTarget

// ─── EXIT SIGNALS ───
if inLong
    if high >= tpPrice
        inLong := false
    if low <= slPrice
        inLong := false
        if not reversed
            stoppedOut := true

if inShort
    if low <= tpPrice
        inShort := false
    if high >= slPrice
        inShort := false
        if not reversed
            stoppedOut := true

// ─── PLOT OPENING RANGE BOX ───
var line orHighLine = na
var line orLowLine  = na
var label orLabel   = na

line.delete(orHighLine)
line.delete(orLowLine)
label.delete(orLabel)

if showORB and orSet
    orHighLine := line.new(time, orHigh, time + (time - time[1]) * 30, orHigh, xloc.bar_time, extend.none, color.new(color.blue, 30), line.style_solid, 2)
    orLowLine  := line.new(time, orLow, time + (time - time[1]) * 30, orLow, xloc.bar_time, extend.none, color.new(color.blue, 30), line.style_solid, 2)
    orLabel    := label.new(time + (time - time[1]) * 15, orHigh, "OR: " + str.tostring(orRange, "#.##") + " pts\nVIX: " + str.tostring(vixClose, "#.#") + "\nStop: " + str.tostring(stopSize, "#.##"), xloc.bar_time, yloc.price, color.new(color.blue, 80), label.style_label_left, color.blue, size.small)

// ─── PLOT ENTRY/TARGET/STOP LEVELS ───
var line buyLine    = na, var line sellLine    = na
var line buyTpLine  = na, var line sellTpLine  = na
var line buySlLine  = na, var line sellSlLine  = na
var label buyLbl    = na, var label sellLbl    = na
var label buyTpLbl  = na, var label sellTpLbl  = na
var label buySlLbl  = na, var label sellSlLbl  = na

line.delete(buyLine), line.delete(sellLine)
line.delete(buyTpLine), line.delete(sellTpLine)
line.delete(buySlLine), line.delete(sellSlLine)
label.delete(buyLbl), label.delete(sellLbl)
label.delete(buyTpLbl), label.delete(sellTpLbl)
label.delete(buySlLbl), label.delete(sellSlLbl)

int ft = time + (time - time[1]) * 50

if showLevels and orSet
    // Buy entry trigger
    buyLine    := line.new(time, buyEntry, ft, buyEntry, xloc.bar_time, extend.none, color.green, line.style_dashed, 1)
    buyLbl     := label.new(ft, buyEntry, "BUY " + str.tostring(buyEntry, format.mintick), xloc.bar_time, yloc.price, color.new(color.green, 80), label.style_label_left, color.green, size.small)

    // Sell entry trigger
    sellLine   := line.new(time, sellEntry, ft, sellEntry, xloc.bar_time, extend.none, color.red, line.style_dashed, 1)
    sellLbl    := label.new(ft, sellEntry, "SELL " + str.tostring(sellEntry, format.mintick), xloc.bar_time, yloc.price, color.new(color.red, 80), label.style_label_left, color.red, size.small)

    // Buy target
    buyTpLine  := line.new(time, buyTarget, ft, buyTarget, xloc.bar_time, extend.none, color.green, line.style_dotted, 2)
    buyTpLbl   := label.new(ft, buyTarget, "BUY TP " + str.tostring(buyTarget, format.mintick), xloc.bar_time, yloc.price, color.new(color.green, 80), label.style_label_left, color.green, size.small)

    // Sell target
    sellTpLine := line.new(time, sellTarget, ft, sellTarget, xloc.bar_time, extend.none, color.red, line.style_dotted, 2)
    sellTpLbl  := label.new(ft, sellTarget, "SELL TP " + str.tostring(sellTarget, format.mintick), xloc.bar_time, yloc.price, color.new(color.red, 80), label.style_label_left, color.red, size.small)

    // Buy stop
    buySlLine  := line.new(time, buyStop, ft, buyStop, xloc.bar_time, extend.none, color.orange, line.style_dotted, 1)
    buySlLbl   := label.new(ft, buyStop, "BUY SL " + str.tostring(buyStop, format.mintick), xloc.bar_time, yloc.price, color.new(color.orange, 80), label.style_label_left, color.orange, size.small)

    // Sell stop
    sellSlLine := line.new(time, sellStop, ft, sellStop, xloc.bar_time, extend.none, color.orange, line.style_dotted, 1)
    sellSlLbl  := label.new(ft, sellStop, "SELL SL " + str.tostring(sellStop, format.mintick), xloc.bar_time, yloc.price, color.new(color.orange, 80), label.style_label_left, color.orange, size.small)

// ─── SIGNAL MARKERS ───
plotshape(buySignal, "BUY", shape.triangleup, location.belowbar, color.lime, size=size.normal, text="ORB BUY")
plotshape(sellSignal, "SELL", shape.triangledown, location.abovebar, color.red, size=size.normal, text="ORB SELL")
plotshape(reverseBuySignal, "REV BUY", shape.triangleup, location.belowbar, color.aqua, size=size.normal, text="FAKEOUT BUY")
plotshape(reverseSellSignal, "REV SELL", shape.triangledown, location.abovebar, color.fuchsia, size=size.normal, text="FAKEOUT SELL")

// ─── IN-TRADE BACKGROUND ───
bgcolor(inLong ? color.new(color.green, 90) : inShort ? color.new(color.red, 90) : na, title="In Trade")

// ─── OPENING RANGE BACKGROUND ───
bgcolor(isORPeriod ? color.new(color.blue, 95) : na, title="OR Period")

// ─── DASHBOARD ───
var table orbDash = table.new(position.top_right, 2, 11, bgcolor=color.rgb(20, 20, 30), border_width=1, border_color=color.gray)

if barstate.islast
    table.cell(orbDash, 0, 0, "OR High", text_color=color.white, text_size=size.small)
    table.cell(orbDash, 1, 0, orSet ? str.tostring(orHigh, format.mintick) : "Building...", text_color=color.green, text_size=size.small)
    table.cell(orbDash, 0, 1, "OR Low", text_color=color.white, text_size=size.small)
    table.cell(orbDash, 1, 1, orSet ? str.tostring(orLow, format.mintick) : "Building...", text_color=color.red, text_size=size.small)
    table.cell(orbDash, 0, 2, "Range", text_color=color.white, text_size=size.small)
    table.cell(orbDash, 1, 2, orSet ? str.tostring(orRange, "#.##") + " pts" : "—", text_color=color.blue, text_size=size.small)
    table.cell(orbDash, 0, 3, "VIX", text_color=color.white, text_size=size.small)
    table.cell(orbDash, 1, 3, str.tostring(vixClose, "#.#"), text_color=vixClose >= vixThreshold ? color.red : color.green, text_size=size.small)
    table.cell(orbDash, 0, 4, "Stop", text_color=color.white, text_size=size.small)
    table.cell(orbDash, 1, 4, not na(stopSize) ? str.tostring(stopSize, "#.##") + " pts" : "—", text_color=color.orange, text_size=size.small)
    table.cell(orbDash, 0, 5, "Buy @", text_color=color.white, text_size=size.small)
    table.cell(orbDash, 1, 5, not na(buyEntry) ? str.tostring(buyEntry, format.mintick) : "—", text_color=color.green, text_size=size.small)
    table.cell(orbDash, 0, 6, "Buy TP", text_color=color.white, text_size=size.small)
    table.cell(orbDash, 1, 6, not na(buyTarget) ? str.tostring(buyTarget, format.mintick) : "—", text_color=color.green, text_size=size.small)
    table.cell(orbDash, 0, 7, "Buy SL", text_color=color.white, text_size=size.small)
    table.cell(orbDash, 1, 7, not na(buyStop) ? str.tostring(buyStop, format.mintick) : "—", text_color=color.orange, text_size=size.small)
    table.cell(orbDash, 0, 8, "Sell @", text_color=color.white, text_size=size.small)
    table.cell(orbDash, 1, 8, not na(sellEntry) ? str.tostring(sellEntry, format.mintick) : "—", text_color=color.red, text_size=size.small)
    table.cell(orbDash, 0, 9, "Sell TP", text_color=color.white, text_size=size.small)
    table.cell(orbDash, 1, 9, not na(sellTarget) ? str.tostring(sellTarget, format.mintick) : "—", text_color=color.red, text_size=size.small)
    table.cell(orbDash, 0, 10, "Sell SL", text_color=color.white, text_size=size.small)
    table.cell(orbDash, 1, 10, not na(sellStop) ? str.tostring(sellStop, format.mintick) : "—", text_color=color.orange, text_size=size.small)

// ─── ALERTS ───
string orbBase = '{"ticker":"MES","strategy":"orb_breakout","key":"lumisignals2026","type":"futures","contracts":1,'
string stopReason = vixClose < vixThreshold ? "VIX<25 fixed " + str.tostring(lowVolStop, "#.#") + "pts" : (orRange > maxRangeStop ? "VIX>=25 range/2 " + str.tostring(orRange/2, "#.#") + "pts" : "VIX>=25 full range " + str.tostring(orRange, "#.#") + "pts")
string orbLevels = '"or_high":' + str.tostring(orHigh, format.mintick) + ',"or_low":' + str.tostring(orLow, format.mintick) + ',"or_range":' + str.tostring(orRange, "#.#") + ',"vix":' + str.tostring(vixClose, "#.#") + ',"stop_size":' + str.tostring(stopSize, "#.#") + ',"stop_reason":"' + stopReason + '",'

if buySignal
    alert(orbBase + '"direction":"BUY","reversal":false,' + orbLevels + '"entry_price":' + str.tostring(buyEntry, format.mintick) + ',"stop_price":' + str.tostring(buyStop, format.mintick) + ',"target_price":' + str.tostring(buyTarget, format.mintick) + '}', alert.freq_once_per_bar_close)
if sellSignal
    alert(orbBase + '"direction":"SELL","reversal":false,' + orbLevels + '"entry_price":' + str.tostring(sellEntry, format.mintick) + ',"stop_price":' + str.tostring(sellStop, format.mintick) + ',"target_price":' + str.tostring(sellTarget, format.mintick) + '}', alert.freq_once_per_bar_close)
if reverseBuySignal
    alert(orbBase + '"direction":"BUY","reversal":true,' + orbLevels + '"entry_price":' + str.tostring(buyEntry, format.mintick) + ',"stop_price":' + str.tostring(buyStop, format.mintick) + ',"target_price":' + str.tostring(buyTarget, format.mintick) + '}', alert.freq_once_per_bar_close)
if reverseSellSignal
    alert(orbBase + '"direction":"SELL","reversal":true,' + orbLevels + '"entry_price":' + str.tostring(sellEntry, format.mintick) + ',"stop_price":' + str.tostring(sellStop, format.mintick) + ',"target_price":' + str.tostring(sellTarget, format.mintick) + '}', alert.freq_once_per_bar_close)
