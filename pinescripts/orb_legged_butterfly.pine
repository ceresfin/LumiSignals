// SPX 0DTE Leg-In Butterfly — Opening Range Breakout
// Apply to: SPX (any timeframe; 1m or 5m recommended)
// Signal:   ES futures breakout of its first 15-min bar (9:30-9:45 ET) +/- offset
// Strikes:  Computed from SPX's own first 15-min bar high/low
//             Long-side  (calls): K1 = SPX_OR_high + 10,  K2 = +15,  K3 = +20
//             Short-side (puts):  K1 = SPX_OR_low  - 10,  K2 = -15,  K3 = -20
//           Rounded to nearest $5 strike. Final = 10-pt butterfly (long K1 / short 2xK2 / long K3).
// Workflow: 1) Buy debit spread K1/K2 on signal  2) After fill, sell credit spread K2/K3
//           Target: debit ~$1.50, credit ~$2.30, net profit ~$70-$90 per fly.
//@version=6
indicator("ORB SPX 0DTE Butterfly", overlay=true, max_lines_count=30, max_labels_count=30)

// ─── INPUTS ───
esSymbol     = input.symbol("CME_MINI:ES1!", "ES Symbol", group="Signal")
orbOffset    = input.float(0.50, "ES Breakout Offset (pts)", step=0.25, group="Signal")
longOff      = input.float(10.0, "Long Strike Offset from SPX OR (pts)", step=1.0, group="Strikes")
shortOff     = input.float(15.0, "Short Strike (body) Offset (pts)", step=1.0, group="Strikes")
wingOff      = input.float(20.0, "Far Wing Strike Offset (pts)", step=1.0, group="Strikes")
strikeStep   = input.float(5.0,  "Strike Grid Step ($)", step=1.0, group="Strikes")
debitTgt     = input.float(1.50, "Target Debit Spread Cost ($)", step=0.05, group="Pricing")
creditTgt    = input.float(2.30, "Target Credit Spread Sale ($)", step=0.05, group="Pricing")
profitTgt    = input.float(80.0, "Target Net Profit ($)", step=5.0, group="Pricing")
lowVolStop   = input.float(4.0,  "ES Stop (VIX < 25, pts)", step=0.5, group="ES Reversal")
vixThreshold = input.int(25,     "VIX Threshold", group="ES Reversal")
maxRangeStop = input.float(20.0, "ES Max Range for Full Stop", step=1.0, group="ES Reversal")
showORB      = input.bool(true,  "Show SPX OR Box", group="Display")
showLevels   = input.bool(true,  "Show Butterfly Strike Lines", group="Display")

// ─── TIME ───
etHour   = hour(time, "America/New_York")
etMinute = minute(time, "America/New_York")
etTime   = etHour * 100 + etMinute

isORPeriod      = etTime >= 930 and etTime < 945
isEntryWindow   = etTime >= 945 and etTime <= 1100
isReversalWindow= etTime >= 945 and etTime <= 1115
isNewSession    = ta.change(time("D")) != 0

// ─── EXTERNAL DATA ───
[esHigh, esLow, esClose] = request.security(esSymbol, timeframe.period, [high, low, close])
vixClose = request.security("TVC:VIX", "D", close)

// ─── OR TRACKING (ES for trigger, SPX for strikes) ───
var float esOrHigh  = na
var float esOrLow   = na
var float spxOrHigh = na
var float spxOrLow  = na
var bool  orSet     = false

if isNewSession
    esOrHigh  := na
    esOrLow   := na
    spxOrHigh := na
    spxOrLow  := na
    orSet     := false

if isORPeriod
    if na(esOrHigh)
        esOrHigh  := esHigh
        esOrLow   := esLow
        spxOrHigh := high
        spxOrLow  := low
    else
        esOrHigh  := math.max(esOrHigh,  esHigh)
        esOrLow   := math.min(esOrLow,   esLow)
        spxOrHigh := math.max(spxOrHigh, high)
        spxOrLow  := math.min(spxOrLow,  low)

if etTime == 945 and not na(esOrHigh) and not orSet
    orSet := true

// ─── ES BREAKOUT LEVELS ───
float esBuyEntry  = orSet ? esOrHigh + orbOffset : na
float esSellEntry = orSet ? esOrLow  - orbOffset : na
float esOrRange   = orSet ? esOrHigh - esOrLow   : na

// ES stop sizing (only used to flag "stopped out" for reversal eligibility)
float esStopSize = na
if orSet
    if vixClose < vixThreshold
        esStopSize := lowVolStop
    else
        esStopSize := esOrRange > maxRangeStop ? esOrRange / 2 : esOrRange

float esBuyStop  = not na(esBuyEntry)  and not na(esStopSize) ? esBuyEntry  - esStopSize : na
float esSellStop = not na(esSellEntry) and not na(esStopSize) ? esSellEntry + esStopSize : na

// ─── SPX BUTTERFLY STRIKES (rounded to nearest grid step) ───
roundStrike(price) =>
    math.round(price / strikeStep) * strikeStep

// Long signal → call butterfly above SPX OR high
float callK1 = orSet ? roundStrike(spxOrHigh + longOff)  : na  // long lower call (debit)
float callK2 = orSet ? roundStrike(spxOrHigh + shortOff) : na  // short body 2x  (debit short + credit short)
float callK3 = orSet ? roundStrike(spxOrHigh + wingOff)  : na  // long upper call (credit)

// Short signal → put butterfly below SPX OR low
float putK1  = orSet ? roundStrike(spxOrLow  - longOff)  : na  // long upper put  (debit)
float putK2  = orSet ? roundStrike(spxOrLow  - shortOff) : na  // short body 2x
float putK3  = orSet ? roundStrike(spxOrLow  - wingOff)  : na  // long lower put  (credit)

// ─── TRADE STATE ───
var bool   inLong     = false
var bool   inShort    = false
var bool   triggered  = false
var bool   reversed   = false
var bool   stoppedOut = false
var string firstDir   = ""

if isNewSession
    inLong     := false
    inShort    := false
    triggered  := false
    reversed   := false
    stoppedOut := false
    firstDir   := ""

// ─── SIGNALS (ES close vs ES breakout levels) ───
buySignal  = orSet and isEntryWindow and not triggered and not inLong and not inShort and esClose > esBuyEntry
sellSignal = orSet and isEntryWindow and not triggered and not inLong and not inShort and esClose < esSellEntry

reverseBuySignal  = orSet and isReversalWindow and stoppedOut and not reversed and not inLong and not inShort and firstDir == "SELL" and esClose > esBuyEntry
reverseSellSignal = orSet and isReversalWindow and stoppedOut and not reversed and not inLong and not inShort and firstDir == "BUY"  and esClose < esSellEntry

if buySignal
    inLong    := true
    triggered := true
    firstDir  := "BUY"
if sellSignal
    inShort   := true
    triggered := true
    firstDir  := "SELL"
if reverseBuySignal
    inLong   := true
    reversed := true
if reverseSellSignal
    inShort  := true
    reversed := true

// ─── ES-LEVEL EXIT TRACKING (for reversal eligibility only) ───
if inLong
    if esClose >= esBuyEntry + 20.0
        inLong := false
    if esClose <= esBuyStop
        inLong := false
        if not reversed
            stoppedOut := true

if inShort
    if esClose <= esSellEntry - 20.0
        inShort := false
    if esClose >= esSellStop
        inShort := false
        if not reversed
            stoppedOut := true

// ─── PLOT SPX OR BOX ───
var line spxHiLine = na
var line spxLoLine = na
var label spxLbl   = na

line.delete(spxHiLine)
line.delete(spxLoLine)
label.delete(spxLbl)

if showORB and orSet
    spxHiLine := line.new(time, spxOrHigh, time + (time - time[1]) * 30, spxOrHigh, xloc.bar_time, extend.none, color.new(color.blue, 30), line.style_solid, 2)
    spxLoLine := line.new(time, spxOrLow,  time + (time - time[1]) * 30, spxOrLow,  xloc.bar_time, extend.none, color.new(color.blue, 30), line.style_solid, 2)
    spxLbl    := label.new(time + (time - time[1]) * 15, spxOrHigh, "SPX OR: " + str.tostring(spxOrHigh - spxOrLow, "#.##") + " pts\nES OR: " + str.tostring(esOrRange, "#.##") + "\nVIX: " + str.tostring(vixClose, "#.#"), xloc.bar_time, yloc.price, color.new(color.blue, 80), label.style_label_left, color.blue, size.small)

// ─── PLOT BUTTERFLY STRIKE LINES ───
var line cK1Ln = na, var line cK2Ln = na, var line cK3Ln = na
var line pK1Ln = na, var line pK2Ln = na, var line pK3Ln = na
var label cK1Lb = na, var label cK2Lb = na, var label cK3Lb = na
var label pK1Lb = na, var label pK2Lb = na, var label pK3Lb = na

line.delete(cK1Ln), line.delete(cK2Ln), line.delete(cK3Ln)
line.delete(pK1Ln), line.delete(pK2Ln), line.delete(pK3Ln)
label.delete(cK1Lb), label.delete(cK2Lb), label.delete(cK3Lb)
label.delete(pK1Lb), label.delete(pK2Lb), label.delete(pK3Lb)

int ft = time + (time - time[1]) * 50

if showLevels and orSet
    // Call butterfly (long signal side)
    cK1Ln := line.new(time, callK1, ft, callK1, xloc.bar_time, extend.none, color.green,  line.style_dashed, 1)
    cK2Ln := line.new(time, callK2, ft, callK2, xloc.bar_time, extend.none, color.lime,   line.style_solid,  2)
    cK3Ln := line.new(time, callK3, ft, callK3, xloc.bar_time, extend.none, color.green,  line.style_dashed, 1)
    cK1Lb := label.new(ft, callK1, "LONG CALL " + str.tostring(callK1, "#"), xloc.bar_time, yloc.price, color.new(color.green, 80), label.style_label_left, color.green, size.small)
    cK2Lb := label.new(ft, callK2, "BODY 2x "   + str.tostring(callK2, "#"), xloc.bar_time, yloc.price, color.new(color.lime,  80), label.style_label_left, color.lime,  size.small)
    cK3Lb := label.new(ft, callK3, "LONG CALL " + str.tostring(callK3, "#"), xloc.bar_time, yloc.price, color.new(color.green, 80), label.style_label_left, color.green, size.small)

    // Put butterfly (short signal side)
    pK1Ln := line.new(time, putK1, ft, putK1, xloc.bar_time, extend.none, color.red,     line.style_dashed, 1)
    pK2Ln := line.new(time, putK2, ft, putK2, xloc.bar_time, extend.none, color.fuchsia, line.style_solid,  2)
    pK3Ln := line.new(time, putK3, ft, putK3, xloc.bar_time, extend.none, color.red,     line.style_dashed, 1)
    pK1Lb := label.new(ft, putK1, "LONG PUT " + str.tostring(putK1, "#"), xloc.bar_time, yloc.price, color.new(color.red,     80), label.style_label_left, color.red,     size.small)
    pK2Lb := label.new(ft, putK2, "BODY 2x "  + str.tostring(putK2, "#"), xloc.bar_time, yloc.price, color.new(color.fuchsia, 80), label.style_label_left, color.fuchsia, size.small)
    pK3Lb := label.new(ft, putK3, "LONG PUT " + str.tostring(putK3, "#"), xloc.bar_time, yloc.price, color.new(color.red,     80), label.style_label_left, color.red,     size.small)

// ─── SIGNAL MARKERS ───
plotshape(buySignal,         "BUY",      shape.triangleup,   location.belowbar, color.lime,    size=size.normal, text="ES BUY → Call Fly")
plotshape(sellSignal,        "SELL",     shape.triangledown, location.abovebar, color.red,     size=size.normal, text="ES SELL → Put Fly")
plotshape(reverseBuySignal,  "REV BUY",  shape.triangleup,   location.belowbar, color.aqua,    size=size.normal, text="REV BUY → Call Fly")
plotshape(reverseSellSignal, "REV SELL", shape.triangledown, location.abovebar, color.fuchsia, size=size.normal, text="REV SELL → Put Fly")

bgcolor(inLong  ? color.new(color.green, 90) : inShort ? color.new(color.red, 90) : na, title="In Trade")
bgcolor(isORPeriod ? color.new(color.blue, 95) : na, title="OR Period")

// ─── DASHBOARD ───
var table dash = table.new(position.top_right, 2, 14, bgcolor=color.rgb(20, 20, 30), border_width=1, border_color=color.gray)

if barstate.islast
    table.cell(dash, 0, 0,  "SPX OR Hi", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 0,  orSet ? str.tostring(spxOrHigh, format.mintick) : "Building...", text_color=color.green, text_size=size.small)
    table.cell(dash, 0, 1,  "SPX OR Lo", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 1,  orSet ? str.tostring(spxOrLow,  format.mintick) : "Building...", text_color=color.red,   text_size=size.small)
    table.cell(dash, 0, 2,  "ES OR Hi",  text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 2,  orSet ? str.tostring(esOrHigh,  format.mintick) : "—", text_color=color.green, text_size=size.small)
    table.cell(dash, 0, 3,  "ES OR Lo",  text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 3,  orSet ? str.tostring(esOrLow,   format.mintick) : "—", text_color=color.red,   text_size=size.small)
    table.cell(dash, 0, 4,  "VIX",       text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 4,  str.tostring(vixClose, "#.#"), text_color=vixClose >= vixThreshold ? color.red : color.green, text_size=size.small)
    table.cell(dash, 0, 5,  "ES Buy @",  text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 5,  not na(esBuyEntry)  ? str.tostring(esBuyEntry,  format.mintick) : "—", text_color=color.green, text_size=size.small)
    table.cell(dash, 0, 6,  "ES Sell @", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 6,  not na(esSellEntry) ? str.tostring(esSellEntry, format.mintick) : "—", text_color=color.red,   text_size=size.small)
    table.cell(dash, 0, 7,  "Call Fly",  text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 7,  orSet ? str.tostring(callK1, "#") + " / " + str.tostring(callK2, "#") + " / " + str.tostring(callK3, "#") : "—", text_color=color.lime, text_size=size.small)
    table.cell(dash, 0, 8,  "Put Fly",   text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 8,  orSet ? str.tostring(putK1, "#") + " / " + str.tostring(putK2, "#") + " / " + str.tostring(putK3, "#") : "—", text_color=color.fuchsia, text_size=size.small)
    table.cell(dash, 0, 9,  "Debit Tgt", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 9,  "$" + str.tostring(debitTgt,  "#.##"), text_color=color.orange, text_size=size.small)
    table.cell(dash, 0, 10, "Credit Tgt",text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 10, "$" + str.tostring(creditTgt, "#.##"), text_color=color.orange, text_size=size.small)
    table.cell(dash, 0, 11, "Profit Tgt",text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 11, "$" + str.tostring(profitTgt, "#.##"), text_color=color.yellow, text_size=size.small)
    table.cell(dash, 0, 12, "State",     text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 12, inLong ? "LONG (Call Fly)" : inShort ? "SHORT (Put Fly)" : triggered ? "Done" : orSet ? "Waiting" : "Pre-OR", text_color=color.aqua, text_size=size.small)
    table.cell(dash, 0, 13, "Stopped?",  text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 13, stoppedOut ? "YES — rev armed" : "no", text_color=stoppedOut ? color.orange : color.gray, text_size=size.small)

// ─── ALERTS (LumiSignals webhook payload) ───
string base = '{"ticker":"SPX","strategy":"orb_butterfly","key":"lumisignals2026","type":"options","structure":"butterfly","expiry":"0DTE","contracts":1,'
string ctx  = '"spx_or_high":' + str.tostring(spxOrHigh, format.mintick) + ',"spx_or_low":' + str.tostring(spxOrLow, format.mintick) + ',"es_or_high":' + str.tostring(esOrHigh, format.mintick) + ',"es_or_low":' + str.tostring(esOrLow, format.mintick) + ',"vix":' + str.tostring(vixClose, "#.#") + ','

string callLegs = '"spread_type":"call","long_strike":' + str.tostring(callK1, "#") + ',"body_strike":' + str.tostring(callK2, "#") + ',"wing_strike":' + str.tostring(callK3, "#") + ','
string putLegs  = '"spread_type":"put","long_strike":'  + str.tostring(putK1,  "#") + ',"body_strike":' + str.tostring(putK2,  "#") + ',"wing_strike":' + str.tostring(putK3,  "#") + ','

string targets = '"debit_target":' + str.tostring(debitTgt, "#.##") + ',"credit_target":' + str.tostring(creditTgt, "#.##") + ',"profit_target":' + str.tostring(profitTgt, "#.##") + '}'

if buySignal
    alert(base + '"direction":"BUY","reversal":false,'  + ctx + callLegs + targets, alert.freq_once_per_bar_close)
if sellSignal
    alert(base + '"direction":"SELL","reversal":false,' + ctx + putLegs  + targets, alert.freq_once_per_bar_close)
if reverseBuySignal
    alert(base + '"direction":"BUY","reversal":true,'   + ctx + callLegs + targets, alert.freq_once_per_bar_close)
if reverseSellSignal
    alert(base + '"direction":"SELL","reversal":true,'  + ctx + putLegs  + targets, alert.freq_once_per_bar_close)
