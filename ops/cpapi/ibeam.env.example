# Copy to ibeam.env on the prod host and fill in the real values.
# chmod 600 ibeam.env  (DO NOT commit the real file)

# IB account credentials. Use the SAME username/password you'd type into the IB
# Gateway login window. For paper trading, this is your paper account login.
IBEAM_ACCOUNT=
IBEAM_PASSWORD=

# Paper or live. Keep 'paper' until cutover is verified end-to-end.
IBEAM_TRADING_MODE=paper

# Optional but useful: pin the gateway's identity so logs and metrics correlate.
IBEAM_GATEWAY_BASE_URL=https://localhost:5000
